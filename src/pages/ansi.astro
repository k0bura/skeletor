    <pre>{`
▒▒▒ ANSI ART ▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒`}</pre>
  </div>

  <p>Classic ANSI art from the BBS scene. Rendered in-browser with <a href="https://github.com/ansilove/ansilove.js">AnsiLove.js</a>. Click a file to view.</p>

  <pre class="file-header">Year  Filename                  Artist              Group</pre>
  <pre class="file-divider">─────────────────────────────────────────────────────────────────────────────</pre>
  {allFiles.map(f => (
    <pre class="file-entry"><span class="file-year">{f.year}</span>  <a href="#" class="ansi-link" data-url={f.url} data-title={f.title} data-artist={f.artist} data-group={f.group} data-year={f.year} data-pack={f.slug} data-file={f.file}>{f.display.padEnd(25)}</a>{f.artist.padEnd(20)}{f.group}</pre>
  ))}
  <pre class="file-divider">─────────────────────────────────────────────────────────────────────────────</pre>
  <pre class="file-footer">{allFiles.length} file(s)</pre>

  <div id="ansi-overlay" class="ansi-overlay">
    <div class="ansi-overlay-inner">
      <div id="ansi-canvas-container" class="ansi-canvas-container"></div>
      <div class="ansi-overlay-footer">
        <span id="ansi-sauce" class="ansi-sauce"></span>
        <a href="#" id="ansi-viewer-close" class="ansi-viewer-close">[ESC] CLOSE</a>
      </div>
    </div>
  </div>

  <p><a href="/">&larr; back to main [ESC]</a></p>
</Base>

<script is:inline src="/ansilove.js"></script>
<script is:inline>
(function() {
  var overlay = document.getElementById('ansi-overlay');
  var container = document.getElementById('ansi-canvas-container');
  var sauceEl = document.getElementById('ansi-sauce');
  var closeBtn = document.getElementById('ansi-viewer-close');

  function formatSauceDate(d) {
    if (!d || d.length !== 8) return d || 'Unknown';
    return d.substring(0, 4) + '-' + d.substring(4, 6) + '-' + d.substring(6, 8);
  }

  function showViewer(url, meta) {
    container.innerHTML = '<pre class="ansi-loading">Rendering...</pre>';
    sauceEl.textContent = '';
    overlay.classList.add('active');
    document.body.style.overflow = 'hidden';

    var opts = { icecolors: 1, "2x": 1 };
    var ext = url.split('.').pop().toLowerCase();
    if (ext === 'ice') {
      opts.filetype = 'ans';
      opts.icecolors = 1;
    }

    AnsiLove.render(url, function(canvas, sauce) {
      container.innerHTML = '';
      canvas.style.imageRendering = 'pixelated';
      container.appendChild(canvas);

      var title = (sauce && sauce.title && sauce.title.trim()) ? sauce.title.trim() : meta.title;
      var artist = (sauce && sauce.author && sauce.author.trim()) ? sauce.author.trim() : meta.artist;
      var group = (sauce && sauce.group && sauce.group.trim()) ? sauce.group.trim() : meta.group;
      var date = (sauce && sauce.date) ? formatSauceDate(sauce.date) : meta.year;

      var parts = ['"' + title + '"', artist, group, date, meta.file];
      if (sauce && sauce.tInfo1 && sauce.tInfo2) {
        parts.push(sauce.tInfo1 + 'x' + sauce.tInfo2);
      }
      sauceEl.textContent = parts.join(' \u00b7 ');
    }, opts, function(err) {
      container.innerHTML = '<pre class="ansi-error">Failed to render: ' + err + '</pre>';
    });
  }

  function hideViewer() {
    overlay.classList.remove('active');
    document.body.style.overflow = '';
    container.innerHTML = '';
    sauceEl.textContent = '';
  }

  document.querySelectorAll('.ansi-link').forEach(function(link) {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      var ds = this.dataset;
      showViewer(ds.url, {
        title: ds.title,
        artist: ds.artist,
        group: ds.group,
        year: ds.year,
        pack: ds.pack,
        file: ds.file
      });
    });
  });

  closeBtn.addEventListener('click', function(e) {
    e.preventDefault();
    hideViewer();
  });

  overlay.addEventListener('click', function(e) {
    if (e.target === overlay || e.target.classList.contains('ansi-overlay-inner')) {
      hideViewer();
    }
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && overlay.classList.contains('active')) {
      e.preventDefault();
      hideViewer();
    }
  });
})();
</script>

