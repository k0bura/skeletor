function truncFile(name: string, max: number): string {
  if (name.length <= max) return name;
  const dot = name.lastIndexOf('.');
  const ext = dot >= 0 ? name.substring(dot) : '';
  const base = dot >= 0 ? name.substring(0, dot) : name;
  const truncLen = max - ext.length - 1;
  return base.substring(0, truncLen) + '\u2026' + ext;
}

const allFiles = packs.flatMap(pack =>
  pack.files.map(f => ({
    ...f,
    group: pack.name,
    year: pack.year,
    slug: pack.slug,
    url: `/ansi/${pack.slug}/${f.file}`,
    display: truncFile(f.file, 25)
  }))
).sort((a, b) => a.year - b.year);
---

<Base title="ANSI Art - sych0net" description="ANSI art gallery rendered with AnsiLove.js">
