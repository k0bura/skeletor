    background: none !important;
    border: none !important;
    padding: 2rem !important;
    text-align: center;
  }

  .ansi-error {
    color: #ff4444;
    background: none !important;
    border: none !important;
    padding: 2rem !important;
    text-align: center;
  }
</style>
